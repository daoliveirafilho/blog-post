---
import { defaultLanguage, useTranslations, type LanguageCode } from '@/i18n/ui';

const lang =
(Astro.currentLocale as LanguageCode | undefined) ?? defaultLanguage;
const tFooter = useTranslations(lang, 'footer');
const tSite = useTranslations(lang, 'site');
---

<footer class="py-6 mt-auto text-center text-sm text-muted-foreground">

<a
href="https://github.com/daoliveirafilho"
>
Github
</a>
|
<a
href="https://medium.com/@da.oliveira.filho"
>
Medium
</a>
|
<a
href="https://openwebui.com/u/daoliveirafilho"
>
Open WebUI
</a>
|
<a
href="https://wasmer.io/daoliveirafilho"
>
Wasmer
</a>



<div class="container mx-auto px-4">
{tSite('title')}
{tFooter('rights')}
</div>
<div class="container mx-auto px-4">
{new Date().getFullYear()}
</div>
</footer>
